# ============================================
# Research Search Engine - Environment Config
# ============================================

# OpenSearch
OPENSEARCH_NODE=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=your_secure_password
OPENSEARCH_INITIAL_ADMIN_PASSWORD=your_secure_password

# MongoDB
MONGODB_URI=mongodb://localhost:27017/research_db

# Redis
REDIS_URL=redis://localhost:6379

# Embedding Service
# transport: http (local dev) | grpc (production — Embed/Rerank via Envoy)
EMBEDDING_TRANSPORT=http
ENVOY_GRPC_TARGET=envoy:10000
EMBEDDING_SERVICE_URL=http://localhost:8001

# East-west gRPC listener (search.v1.SearchService)
GRPC_ENABLED=true
GRPC_BIND_ADDRESS=0.0.0.0:50053

# API Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Search pipeline (retrieve-then-rerank). CANDIDATE_K must match
# RERANK_MAX_CANDIDATES on the embedding service — tuned down from 50 to
# keep CPU-only rerank latency reasonable (see embedding/.env.example).
CANDIDATE_K=25
RERANK_ENABLED=true
# 800ms is too tight for a real CPU cross-encoder rerank batch (measured
# ~3.7-9.5s depending on CANDIDATE_K/RERANK_MAX_LENGTH) and was silently
# falling back to first-stage ranking on every request; 15s gives real
# batches room to complete.
RERANK_TIMEOUT_MS=15000
RERANK_MODEL_VERSION=bge-reranker-base-v1
RERANK_CACHE_TTL=3600
