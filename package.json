{
  "name": "research-search-api",
  "version": "1.0.0",
  "description": "Academic research search engine API with hybrid BM25 + semantic search",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node --test tests/regression_search.test.mjs tests/perf_search.test.mjs tests/author_scope_search.test.mjs tests/unit/*.test.mjs tests/integration/*.test.mjs tests/corpus_retrieval.test.mjs",
    "test:dump": "node tests/scripts/dump_test_corpus.mjs",
    "test:golden": "node tests/scripts/generate_golden_set.mjs",
    "test:golden:hard": "node tests/scripts/generate_hard_golden_set.mjs",
    "test:corpus": "node --test tests/corpus_retrieval.test.mjs",
    "test:hard": "node --test tests/hard_retrieval.test.mjs",
    "test:eval": "node tests/eval/eval_harness.mjs",
    "test:eval:hard": "node tests/eval/eval_hard.mjs",
    "test:invariants": "node --test tests/integration/search_invariants.test.mjs tests/integration/refinement_chain.test.mjs",
    "test:refine": "node --test tests/integration/refinement_chain.test.mjs",
    "test:retrieval": "node --test tests/retrieval_quality.test.mjs tests/corpus_retrieval.test.mjs tests/hard_retrieval.test.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/sensible": "^6.0.4",
    "@opensearch-project/opensearch": "^2.5.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "mongoose": "^8.0.3",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
