# ── Embedding Service Configuration ──

# Server
PORT=8001
HOST=0.0.0.0

# Model (BGE-base 768-dim, ONNX Runtime on CPU)
MODEL_NAME=BAAI/bge-base-en-v1.5
EMBED_DIM=768
EMBED_BACKEND=onnx
MAX_BATCH_SIZE=600
MAX_LENGTH=512
POOLING=cls
NORMALIZE=true
USE_GPU=false

# ── CPU tuning (standalone mode) ──
TORCH_THREADS=0
TORCH_INTEROP_THREADS=1
EMBED_SUB_BATCH=8
HF_OFFLINE=auto
LOG_LEVEL=INFO

# ── Cross-encoder reranker ──
RERANK_ENABLED=true
RERANK_MODEL_NAME=BAAI/bge-reranker-base
RERANK_MAX_LENGTH=320
RERANK_MAX_CANDIDATES=100
RERANK_SUB_BATCH=16

# ── Load Balancer / Gateway Mode ──
# BACKEND_NODES=http://10.0.0.1:8000,http://10.0.0.2:8000
HEALTH_CHECK_INTERVAL_S=10
NODE_TIMEOUT_S=60
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_S=30
SCATTER_MIN_BATCH=16
MAX_INFLIGHT_PER_NODE=2
LATENCY_BASE_MS=100
LATENCY_FLOOR_MS=50
MIN_NODE_WEIGHT=0.1
HALF_OPEN_PROBE_TEXTS=4
NODE_ACQUIRE_TIMEOUT_S=0
