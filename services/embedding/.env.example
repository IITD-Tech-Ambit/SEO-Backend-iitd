# ── Embedding Service Configuration ──

# Server
PORT=8000
HOST=0.0.0.0

# Model
MODEL_NAME=BAAI/bge-base-en-v1.5
EMBED_DIM=768
EMBED_BACKEND=onnx
MAX_BATCH_SIZE=32
MAX_LENGTH=512
POOLING=cls
NORMALIZE=true
USE_GPU=false

# CPU tuning (standalone mode)
ORT_NUM_THREADS=4
TORCH_THREADS=4
TORCH_INTEROP_THREADS=1
EMBED_SUB_BATCH=4
HF_OFFLINE=auto
LOG_LEVEL=INFO

# Cross-encoder reranker. BAAI/bge-reranker-base (XLM-RoBERTa-base, 768
# hidden) was genuinely too slow for CPU-only inference at production
# corpus size — measured ~9.5s for 50 docs at 320 tokens on a 16-core box,
# not a routing/config issue, just the real cost of that architecture here.
#
# The original L-12 pick (see git history) was benchmarked at 12 docs/query,
# where L-6 and L-12 measured near-identical latency - but production reranks
# candidateK=50 docs, a batch size that comparison never tested. Re-benchmarked
# both at the real 50-doc scale against 4 real corpus queries (live results,
# not synthetic text): L-12 averaged ~3.5s vs L-6 ~1.9s (~1.85x), and L-6's
# top-1 result matched L-12's exactly in 4/4 queries, with 4.2/5 average
# top-5 overlap - no measurable quality loss at this scale, consistently
# faster. Reverted to L-6. Must match CANDIDATE_K in the search-api env.
# bge-reranker-v2-m3 was ruled out earlier as architecturally too heavy for
# CPU (~9.5s/50docs, not a config issue).
RERANK_ENABLED=true
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MAX_LENGTH=320
RERANK_MAX_CANDIDATES=50
RERANK_SUB_BATCH=8
RERANK_QUANTIZE=true
# ONNX_INT8_CACHE_DIR=.cache/onnx_int8

# In-process concurrency per worker for local embed/rerank inference (not the
# gateway/multi-node settings below). Each session already uses
# ORT_NUM_THREADS internally, so WEB_CONCURRENCY x this x ORT_NUM_THREADS
# should stay near the host's core count.
EMBED_MAX_CONCURRENCY=2
RERANK_MAX_CONCURRENCY=2
INFER_QUEUE_TIMEOUT_S=30

# Load Balancer / Gateway Mode (leave BACKEND_NODES empty for standalone)
# BACKEND_NODES=http://10.0.0.1:8000,http://10.0.0.2:8000
HEALTH_CHECK_INTERVAL_S=10
NODE_TIMEOUT_S=60
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_S=30
SCATTER_MIN_BATCH=16
MAX_INFLIGHT_PER_NODE=2
LATENCY_BASE_MS=100
LATENCY_FLOOR_MS=50
MIN_NODE_WEIGHT=0.1
HALF_OPEN_PROBE_TEXTS=4
NODE_ACQUIRE_TIMEOUT_S=0
