# ── Embedding Service Configuration ──

# Server
PORT=8000
HOST=0.0.0.0

# Model
MODEL_NAME=BAAI/bge-base-en-v1.5
EMBED_DIM=768
EMBED_BACKEND=onnx
MAX_BATCH_SIZE=32
MAX_LENGTH=512
POOLING=cls
NORMALIZE=true
USE_GPU=false

# CPU tuning (standalone mode)
ORT_NUM_THREADS=4
TORCH_THREADS=4
TORCH_INTEROP_THREADS=1
EMBED_SUB_BATCH=4
HF_OFFLINE=auto
LOG_LEVEL=INFO

# Cross-encoder reranker. BAAI/bge-reranker-base (XLM-RoBERTa-base, 768
# hidden) was genuinely too slow for CPU-only inference at production
# corpus size — measured ~9.5s for 50 docs at 320 tokens on a 16-core box,
# not a routing/config issue, just the real cost of that architecture here.
# cross-encoder/ms-marco-MiniLM-L-6-v2 (MiniLM, 384 hidden, 6 layers) is the
# standard fast/reliable reranker for exactly this RAG use case: same
# relative ranking behavior verified against bge-reranker-base on a mixed
# relevant/irrelevant test set, ~1.2s for the SAME full 50-doc/320-token
# window (no need to truncate candidates/length like bge-reranker-base
# required). Must match CANDIDATE_K in the search-api env.
RERANK_ENABLED=true
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MAX_LENGTH=320
RERANK_MAX_CANDIDATES=50
RERANK_SUB_BATCH=8
RERANK_QUANTIZE=true
# ONNX_INT8_CACHE_DIR=.cache/onnx_int8

# Load Balancer / Gateway Mode (leave BACKEND_NODES empty for standalone)
# BACKEND_NODES=http://10.0.0.1:8000,http://10.0.0.2:8000
HEALTH_CHECK_INTERVAL_S=10
NODE_TIMEOUT_S=60
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_S=30
SCATTER_MIN_BATCH=16
MAX_INFLIGHT_PER_NODE=2
LATENCY_BASE_MS=100
LATENCY_FLOOR_MS=50
MIN_NODE_WEIGHT=0.1
HALF_OPEN_PROBE_TEXTS=4
NODE_ACQUIRE_TIMEOUT_S=0
