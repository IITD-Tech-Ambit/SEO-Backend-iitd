# ── Embedding Service Configuration ──

# Server
PORT=8001
HOST=0.0.0.0

# Model (used in standalone mode)
MODEL_NAME=BAAI/bge-m3
MAX_BATCH_SIZE=600
MAX_LENGTH=1024
# Output dimensionality (BGE-M3 dense = 1024; SPECTER2 = 768)
EMBED_DIM=1024
# Pooling: "cls" for BGE-M3 dense, "mean" for SPECTER2-style
POOLING=cls
NORMALIZE=true
USE_GPU=false

# ── CPU tuning (standalone mode) ──
# Torch intra-op threads (0 = all cores) and inter-op queues (keep at 1).
TORCH_THREADS=0
TORCH_INTEROP_THREADS=1
# Texts per forward pass; lower = less peak RAM (attention is batch x seq^2).
EMBED_SUB_BATCH=8
# Model loading: "auto" = local HF cache first, download only if missing;
# "true" = never touch the network; "false" = normal hub behavior.
HF_OFFLINE=auto

# Logging
LOG_LEVEL=INFO

# ── Load Balancer / Gateway Mode ──
# Set BACKEND_NODES to run as a gateway that distributes requests across GPU nodes.
# Leave empty (or unset) to run in standalone mode with a local model.
# Example: BACKEND_NODES=http://10.0.0.1:8000,http://10.0.0.2:8000,http://10.0.0.3:8000

# Health check interval for backend nodes (seconds)
HEALTH_CHECK_INTERVAL_S=10

# HTTP timeout for requests to backend nodes (seconds)
NODE_TIMEOUT_S=60

# Circuit breaker: consecutive failures before marking a node as down
CIRCUIT_BREAKER_THRESHOLD=3

# Circuit breaker: seconds to wait before retrying a tripped node
CIRCUIT_BREAKER_RECOVERY_S=30

# Batches smaller than this are sent to a single node; larger batches are
# scattered across all healthy nodes in parallel.
SCATTER_MIN_BATCH=16

# ── Dynamic load balancing ──
# Max concurrent in-flight requests to a single backend (per gateway process).
# Should roughly equal the backend's uvicorn worker count + 1 for pipelining.
MAX_INFLIGHT_PER_NODE=2

# Latency normalizer for capacity scoring (ms). A node at this latency with
# 1 in-flight request gets weight ~1.0.
LATENCY_BASE_MS=100

# Floor used when a node has no observed latency yet (cold start).
LATENCY_FLOOR_MS=50

# Minimum share a healthy node must receive in weighted scatter.
MIN_NODE_WEIGHT=0.1

# Max texts sent to a half-open (circuit recovery) node when probing.
HALF_OPEN_PROBE_TEXTS=4

# Per-node semaphore acquire timeout for scatter chunks (seconds). 0 = no wait.
NODE_ACQUIRE_TIMEOUT_S=0
